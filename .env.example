MONGO_URI=mongodb+srv://yourusername:yourpassword@cluster0.xxxxx.mongodb.net/devflow?retryWrites=true&w=majority
MONGO_DB_NAME=devflow
JWT_SECRET=replace_with_a_long_random_secret
PORT=3000
# Note: Create free MongoDB Atlas cluster, whitelist 0.0.0.0/0, get URI from Atlas dashboard, replace credentials
# For Vercel, add MONGO_URI, MONGO_DB_NAME, and JWT_SECRET in Project Settings -> Environment Variables
